---
import Layout from '../layouts/Layout.astro';
import Email from '../components/Email.astro';
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * THE DARKROOM — how to add photos:
 *
 * 1. Drop your raw image files (JPG/PNG/WebP, full resolution is fine) into:
 *        src/assets/photography/
 * 2. That's it. The glob below picks them up automatically, and Astro's
 *    <Image /> component optimizes each one at build time (resized,
 *    compressed, converted to WebP, with width/height set to prevent
 *    layout shift). Never put gallery photos in /public — files there
 *    skip Astro's optimization pipeline entirely.
 *
 * Files are sorted by filename, so prefix with numbers to control order:
 *    01-golden-hour.jpg, 02-street-kyoto.jpg, ...
 */
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/photography/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);

const photos = await Promise.all(
  Object.entries(modules)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(async ([path, mod]) => ({
      src: mod.default,
      // Larger rendition served by the click-to-expand lightbox
      full: await getImage({
        src: mod.default,
        width: Math.min(2560, mod.default.width),
        format: 'webp',
      }),
      // "01-golden-hour.jpg" → "golden hour" (used for alt text; rename
      // files descriptively or replace this with a proper caption map)
      alt: (path.split('/').pop() ?? '')
        .replace(/\.[^.]+$/, '')
        .replace(/^\d+[-_]?/, '')
        .replace(/[-_]+/g, ' '),
    }))
);
---

<Layout title="jinfusion · the darkroom" description="Photography by jinfusion — portraits, streets, and light experiments.">
  <main class="mx-auto max-w-6xl px-6 py-16">
    <header class="mb-12">
      <a
        href="/"
        class="font-mono text-sm text-zinc-500 transition-colors duration-300 hover:text-zinc-200"
      >
        ← cd ~/lobby
      </a>
      <h1 class="mt-6 text-4xl font-bold tracking-tight text-zinc-100 sm:text-5xl">
        The Darkroom
      </h1>
      <p class="mt-4 max-w-xl text-lg leading-relaxed text-zinc-400">
        Photographs, developed in the digital dark. Prints and commissions via <Email
          user="commissions"
          class="text-zinc-200 underline decoration-zinc-700 underline-offset-4 transition-colors duration-300 hover:decoration-zinc-300"
        />.
      </p>
    </header>

    {
      photos.length > 0 ? (
        <div class="columns-1 gap-5 md:columns-2 lg:columns-3 [&>*]:mb-5">
          {photos.map((photo) => (
            <figure class="group break-inside-avoid overflow-hidden rounded-xl border border-zinc-800/80 bg-zinc-900/50 transition-all duration-300 hover:border-zinc-600">
              <button
                type="button"
                data-lightbox-trigger
                data-full={photo.full.src}
                data-alt={photo.alt}
                class="block w-full cursor-zoom-in"
                aria-label={`View ${photo.alt || 'photo'} full size`}
              >
                <Image
                  src={photo.src}
                  alt={photo.alt}
                  widths={[480, 800, 1200]}
                  sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
                  class="w-full transition-transform duration-500 group-hover:scale-[1.02]"
                />
              </button>
            </figure>
          ))}
        </div>
      ) : (
        <div class="rounded-xl border border-dashed border-zinc-800 p-12 text-center">
          <p class="font-mono text-sm text-zinc-500">// darkroom is empty</p>
          <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-zinc-400">
            Drop image files into <code class="rounded bg-zinc-900 px-1.5 py-0.5 font-mono text-xs text-zinc-300">src/assets/photography/</code> and
            rebuild — they'll appear here automatically, optimized by Astro.
          </p>
        </div>
      )
    }

    {
      photos.length > 0 && (
        <dialog
          id="lightbox"
          class="m-0 h-dvh max-h-none w-screen max-w-none bg-transparent p-0 backdrop:bg-zinc-950/95"
        >
          <div class="flex h-full w-full flex-col items-center justify-center gap-5 p-4 sm:p-8">
            <img
              data-lightbox-img
              class="max-h-[82dvh] max-w-full rounded-lg object-contain shadow-2xl"
              alt=""
            />
            <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 font-mono text-xs">
              <button
                type="button"
                data-lightbox-prev
                class="text-zinc-400 transition-colors duration-300 hover:text-zinc-100"
              >
                ← prev
              </button>
              <p data-lightbox-counter class="text-zinc-600" aria-live="polite"></p>
              <button
                type="button"
                data-lightbox-next
                class="text-zinc-400 transition-colors duration-300 hover:text-zinc-100"
              >
                next →
              </button>
              <button
                type="button"
                data-lightbox-close
                class="text-zinc-500 transition-colors duration-300 hover:text-zinc-100"
              >
                [esc] close
              </button>
            </div>
          </div>
        </dialog>
      )
    }
  </main>
</Layout>

<script>
  function getDialog() {
    return document.querySelector<HTMLDialogElement>('#lightbox');
  }

  function getTriggers() {
    return [...document.querySelectorAll<HTMLElement>('[data-lightbox-trigger]')];
  }

  function render(i: number) {
    const dialog = getDialog();
    const triggers = getTriggers();
    if (!dialog || triggers.length === 0) return;
    const n = ((i % triggers.length) + triggers.length) % triggers.length;
    dialog.dataset.index = String(n);
    const trigger = triggers[n];
    const img = dialog.querySelector<HTMLImageElement>('[data-lightbox-img]');
    const counter = dialog.querySelector('[data-lightbox-counter]');
    if (img) {
      img.src = trigger.dataset.full ?? '';
      img.alt = trigger.dataset.alt ?? '';
    }
    if (counter) counter.textContent = `// ${n + 1} of ${triggers.length}`;
  }

  function step(delta: number) {
    const dialog = getDialog();
    if (!dialog?.open) return;
    render(Number(dialog.dataset.index ?? 0) + delta);
  }

  document.addEventListener('click', (e) => {
    const el = e.target as HTMLElement;
    const trigger = el.closest<HTMLElement>('[data-lightbox-trigger]');
    if (trigger) {
      render(getTriggers().indexOf(trigger));
      getDialog()?.showModal();
      return;
    }
    if (el.closest('[data-lightbox-prev]')) return step(-1);
    if (el.closest('[data-lightbox-next]')) return step(1);
    if (el.closest('[data-lightbox-close]')) return getDialog()?.close();
    // Click on the empty area around the photo closes the lightbox; the
    // flex wrapper fills the dialog, so any non-child target is backdrop.
    const dialog = getDialog();
    if (dialog?.open && (el === dialog || el.parentElement === dialog)) dialog.close();
  });

  document.addEventListener('keydown', (e) => {
    if (!getDialog()?.open) return;
    if (e.key === 'ArrowRight') step(1);
    if (e.key === 'ArrowLeft') step(-1);
  });
</script>
