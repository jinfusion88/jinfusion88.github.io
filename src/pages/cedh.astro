---
import Layout from '../layouts/Layout.astro';
import Email from '../components/Email.astro';

const destinations = [
  {
    name: 'Articles',
    handle: '~/cedh/articles',
    blurb: 'Long-form deck engineering writeups — starting with the Ghost-Spider Codex, a six-build journey to sticky Jenga.',
    href: '/cedh/articles',
    accent: 'text-violet-400',
    glow: 'group-hover:shadow-violet-400/10',
    external: false,
  },
  {
    name: 'YouTube',
    handle: '@Jinfusion',
    blurb: 'cEDH gameplay, deck techs, and strategy breakdowns.',
    href: 'https://www.youtube.com/@Jinfusion',
    accent: 'text-rose-400',
    glow: 'group-hover:shadow-rose-400/10',
    external: true,
  },
  {
    name: 'Moxfield',
    handle: 'JeskaiJin',
    blurb: 'Decklists — tournament lists, brews, and works in progress.',
    href: 'https://moxfield.com/users/JeskaiJin',
    accent: 'text-amber-400',
    glow: 'group-hover:shadow-amber-400/10',
    external: true,
  },
  {
    name: 'Bluesky',
    handle: 'jinfusion.bsky.social',
    blurb: 'Takes, spoiler-season reactions, and event updates.',
    href: 'https://bsky.app/profile/jinfusion.bsky.social',
    accent: 'text-sky-400',
    glow: 'group-hover:shadow-sky-400/10',
    external: true,
  },
];
---

<Layout title="jinfusion · cEDH" description="cEDH content and decklists by jinfusion — YouTube strategy videos, Moxfield decklists, and Bluesky.">
  <main class="mx-auto max-w-3xl px-6 py-16">
    <a
      href="/"
      class="font-mono text-sm text-zinc-500 transition-colors duration-300 hover:text-zinc-200"
    >
      ← cd ~/lobby
    </a>
    <h1 class="mt-6 text-4xl font-bold tracking-tight text-zinc-100 sm:text-5xl">
      cEDH — Content &amp; Decklists
    </h1>
    <p class="mt-4 max-w-xl text-lg leading-relaxed text-zinc-400">
      Competitive Commander, taken apart on camera and rebuilt card by card.
      Videos, lists, and the running commentary live here. Collabs and
      inquiries via <Email
        user="cedh"
        class="text-zinc-200 underline decoration-zinc-700 underline-offset-4 transition-colors duration-300 hover:decoration-zinc-300"
      />.
    </p>

    <div class="mt-12 flex flex-col gap-5">
      {
        destinations.map((d) => (
          <a
            href={d.href}
            target={d.external ? '_blank' : undefined}
            rel={d.external ? 'noopener' : undefined}
            class:list={[
              'group rounded-xl border border-zinc-800/80 bg-zinc-900/40 p-6',
              'transition-all duration-300 hover:-translate-y-0.5 hover:border-zinc-600 hover:bg-zinc-900 hover:shadow-xl',
              d.glow,
            ]}
          >
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <span class="flex flex-wrap items-baseline gap-x-3">
                <span class:list={['text-lg font-semibold', d.accent]}>{d.name}</span>
                <span class="font-mono text-sm text-zinc-500 transition-colors duration-300 group-hover:text-zinc-300">{d.handle}</span>
              </span>
              <span class="font-mono text-xs text-zinc-600 transition-all duration-300 group-hover:translate-x-1 group-hover:text-zinc-200">
                {d.external ? '↗' : '→'}
              </span>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-zinc-400">{d.blurb}</p>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
